# Copy this file to secrets.toml and fill in your real values.
# secrets.toml is gitignored — never commit it.
#
# Usage: .streamlit/secrets.toml is loaded automatically by Streamlit.
# All values are accessible via st.secrets.get("KEY", "").

# ── Finnhub ───────────────────────────────────────────────────────────────────
FINNHUB_API_KEY   = ""     # https://finnhub.io — free tier

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = ""     # https://console.anthropic.com — optional

# ── SMTP email ────────────────────────────────────────────────────────────────
SMTP_HOST     = ""         # e.g. "smtp.gmail.com"
SMTP_PORT     = 587        # 587 for STARTTLS, 465 for SSL
SMTP_USER     = ""         # sender email address
SMTP_PASSWORD = ""         # app password (NOT login password)
